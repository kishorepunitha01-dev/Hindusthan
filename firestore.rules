rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(data) { return isSignedIn() && data.userId == request.auth.uid; }
    function isAdmin() { 
      return isSignedIn() && 
             (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
              request.auth.token.email == 'kishorepunitha01@gmail.com'); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation schemas
    function isValidEvent(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.date is string &&
             data.venue is string && data.venue.size() <= 200;
    }
    
    function isValidNotice(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000;
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.authors is string && data.authors.size() <= 200;
    }

    function isValidGallery(data) {
      return data.url is string && data.url.size() <= 1000;
    }

    // Collections
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() && isValidEvent(incoming());
      allow update: if isAdmin() && isValidEvent(incoming());
      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNotice(incoming());
      allow update: if isAdmin() && isValidNotice(incoming());
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isVerified() && isValidProject(incoming());
      allow update: if (isVerified() && isOwner(existing()) && isValidProject(incoming())) || isAdmin();
      allow delete: if (isVerified() && isOwner(existing())) || isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow create: if isAdmin() && isValidGallery(incoming());
      allow update: if isAdmin() && isValidGallery(incoming());
      allow delete: if isAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && 
                    incoming().studentId == request.auth.uid && 
                    incoming().timestamp == request.time;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
